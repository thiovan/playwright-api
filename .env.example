# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Worker ─────────────────────────────────────────────────────────────────────
CONCURRENCY=3

# ── Timeouts (milliseconds) ───────────────────────────────────────────────────
ACTION_TIMEOUT=60000
WORKFLOW_TIMEOUT=300000
WEBHOOK_TIMEOUT=30000
